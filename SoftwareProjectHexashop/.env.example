# Copy this file to .env and set real values locally.
# Do not commit .env.

# Local docker-compose postgres container settings
POSTGRES_DB=hexashopdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# App datasource and auth settings
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/hexashopdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change_me
APP_LOGIN_USER=admin
APP_LOGIN_PASSWORD=change_me
PORT=8080
